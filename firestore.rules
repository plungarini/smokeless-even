rules_version = '2';

// Smokeless Firestore rules.
//
// Data model (Google mode only — Local mode stays out of Firestore):
//   /users/{uid}                — canonical user doc + preferences.
//   /users/{uid}/logs/{logId}   — smoke log entries.
//   /handoffCodes/{code}        — short-lived Google sign-in handoff docs.
//                                 Managed exclusively by Cloud Functions
//                                 (admin SDK) — clients never read/write.
//   /googleSessions/{uid}       — hashed rotating session tokens.
//                                 Managed exclusively by Cloud Functions.

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function isUserOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow get, create, update, delete: if isUserOwner(uid);
      allow list: if false;

      match /logs/{logId} {
        allow get, list, create, update, delete: if isUserOwner(uid);
      }
    }

    match /handoffCodes/{code} {
      // All access goes through Cloud Functions (admin SDK). Clients poll
      // via callables, never direct reads/writes.
      allow read, write: if false;
    }

    match /googleSessions/{uid} {
      allow read, write: if false;
    }
  }
}
